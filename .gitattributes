# Normalise line endings: store as LF in the repo, checkout as native on each OS
* text=auto

# Force LF for files that must not have CRLF
*.py text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.lock text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.env text eol=lf
*.txt text eol=lf

# Binary files — no line ending conversion
*.pdf binary
*.png binary
*.jpg binary
